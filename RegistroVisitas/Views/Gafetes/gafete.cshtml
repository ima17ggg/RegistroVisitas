@using RegistroVisitas.Models.ViewModels
@model VigilanciaViewModel
@{
    Layout = null; 
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Gafete de Visitante</title>

    <style>
        body {
            font-family: Arial, sans-serif;
        }

        .gafete {
            width: 350px;
            height: 220px;
            border: 2px solid #000;
            padding: 10px;
            display: flex;
            gap: 10px;
        }

        .foto {
            width: 100px;
            height: 120px;
            border: 1px solid #000;
            object-fit: cover;
        }

        .info {
            flex: 1;
        }

        .nombre {
            font-weight: bold;
            font-size: 16px;
        }

        .compania {
            font-size: 14px;
            margin-bottom: 10px;
        }

        .qr {
            width: 80px;
            height: 80px;
        }
    </style>
</head>

<body>
    <div class="gafete">
        <img src="@Model.foto" class="foto" />

        <div class="info">
            <div class="nombre">
                @Model.nombre @Model.apellido_p @Model.apellido_m
            </div>

            <div class="compania">
                @Model.compania
            </div>

            <img class="qr"
                 src="@(Model.QRCodeData != null ? $"data:image/png;base64,{Convert.ToBase64String(Model.QRCodeData)}" : "")" />
        </div>
    </div>
</body>
</html>

